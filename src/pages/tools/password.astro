---
import Layout from "@/layouts/Layout.astro";
import "@/styles/global.css";
---

<Layout>
  <main>
    <section class="tool-section section-border animation-appear fadeIn">
      <a class="back" href="/">← Volver</a>
      <h1>Generador de Contraseñas</h1>
      <p class="subtitle">
        Genera contraseñas seguras y aleatorias con opciones personalizables.
      </p>

      <form id="password-form" autocomplete="off">
        <label for="length">Caracteres</label>
        <div class="slider-container">
          <input
            type="range"
            id="length"
            name="length"
            min="8"
            max="128"
            value="20"
          />
          <span class="slider-value">20</span>
        </div>

        <div class="toggles-group">
          <div class="toggle-item">
            <input type="checkbox" id="lowercase" name="lowercase" checked />
            <label for="lowercase" class="toggle-label">Letras</label>
          </div>

          <div class="toggle-item">
            <input type="checkbox" id="uppercase" name="uppercase" checked />
            <label for="uppercase" class="toggle-label">Letras mayúsculas</label
            >
          </div>

          <div class="toggle-item">
            <input type="checkbox" id="numbers" name="numbers" checked />
            <label for="numbers" class="toggle-label">Números</label>
          </div>

          <div class="toggle-item">
            <input type="checkbox" id="symbols" name="symbols" />
            <label for="symbols" class="toggle-label">Símbolos</label>
          </div>
        </div>

        <label for="password-output">Contraseña generada</label>
        <p id="password-output"></p>

        <div class="actions">
          <button id="generate" type="button">Generar</button>
          <button id="copy" type="button" disabled>Copiar</button>
        </div>
      </form>

      <div id="copy-feedback" class="copy-feedback"></div>
    </section>
  </main>

  <script type="module">
    const lengthInput = document.getElementById("length");
    const lengthValue = document.querySelector(".slider-value");
    const lowercaseToggle = document.getElementById("lowercase");
    const uppercaseToggle = document.getElementById("uppercase");
    const numbersToggle = document.getElementById("numbers");
    const symbolsToggle = document.getElementById("symbols");
    const passwordOutput = document.getElementById("password-output");
    const generateBtn = document.getElementById("generate");
    const copyBtn = document.getElementById("copy");
    const copyFeedback = document.getElementById("copy-feedback");

    const lowercase = "abcdefghijklmnopqrstuvwxyz";
    const uppercase = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
    const numbers = "0123456789";
    const symbols = "!@#$%^&*()_+-=[]{}|;:,.<>?";

    // Actualizar el valor visible del slider
    lengthInput?.addEventListener("input", (e) => {
      lengthValue.textContent = e.target.value;
      generatePassword();
    });

    // Regenerar contraseña al cambiar opciones
    [lowercaseToggle, uppercaseToggle, numbersToggle, symbolsToggle].forEach(
      (toggle) => {
        toggle?.addEventListener("change", generatePassword);
      },
    );

    function generatePassword() {
      let chars = "";
      if (lowercaseToggle?.checked) chars += lowercase;
      if (uppercaseToggle?.checked) chars += uppercase;
      if (numbersToggle?.checked) chars += numbers;
      if (symbolsToggle?.checked) chars += symbols;

      if (chars.length === 0) {
        if (passwordOutput)
          passwordOutput.textContent = "Selecciona al menos una opción";
        if (copyBtn) copyBtn.disabled = true;
        return;
      }

      const length = parseInt(lengthInput?.value || 20);
      let password = "";

      for (let i = 0; i < length; i++) {
        password += chars.charAt(Math.floor(Math.random() * chars.length));
      }

      if (passwordOutput) passwordOutput.textContent = password;
      if (copyBtn) copyBtn.disabled = false;
    }

    generateBtn?.addEventListener("click", (e) => {
      e.preventDefault();
      generatePassword();
    });

    copyBtn?.addEventListener("click", async (e) => {
      e.preventDefault();

      if (
        !passwordOutput?.textContent ||
        passwordOutput.textContent === "Selecciona al menos una opción"
      ) {
        return;
      }

      try {
        await navigator.clipboard.writeText(passwordOutput.textContent);

        // Mostrar feedback
        if (copyFeedback) {
          copyFeedback.textContent = "¡Contraseña copiada!";
          copyFeedback.classList.add("show");

          setTimeout(() => {
            copyFeedback.classList.remove("show");
          }, 2000);
        }
      } catch (err) {
        console.error("Error al copiar:", err);
        if (copyFeedback) {
          copyFeedback.textContent = "Error al copiar";
          copyFeedback.classList.add("show");

          setTimeout(() => {
            copyFeedback.classList.remove("show");
          }, 2000);
        }
      }
    });

    // Generar contraseña inicial
    generatePassword();
  </script>

  <style>
    main {
      min-height: 100vh;
      display: grid;
      place-items: center;
      padding: 40px 0;
    }

    .tool-section {
      width: min(700px, 90%);
      border-radius: 5px;
      margin: 0 auto;
    }

    .back {
      color: var(--light-theme-primary-text);
      text-decoration: none;
      font-weight: 500;
      display: inline-flex;
      margin-bottom: 12px;
      transition: transform 0.1s;
    }

    .back:hover {
      transform: translateX(-2px);
    }

    h1 {
      color: var(--light-theme-primary-text);
      font-weight: 700;
      line-height: 1.2;
      font-size: 2rem;
    }

    .subtitle {
      margin: 10px 0 24px;
      color: var(--light-theme-secondary-text);
      font-size: 16px;
    }

    form {
      display: grid;
      gap: 12px;
    }

    label {
      display: block;
      margin-bottom: 6px;
      color: var(--light-theme-primary-text);
      font-weight: 500;
    }

    input[type="range"] {
      width: 100%;
      height: 6px;
      border-radius: 3px;
      outline: none;
      -webkit-appearance: none;
      appearance: none;
      background: #dadada;
    }

    input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance: none;
      appearance: none;
      width: 18px;
      height: 18px;
      border-radius: 50%;
      background: var(--blue);
      cursor: pointer;
    }

    input[type="range"]::-moz-range-thumb {
      width: 18px;
      height: 18px;
      border-radius: 50%;
      background: var(--blue);
      cursor: pointer;
      border: none;
    }

    .slider-container {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .slider-value {
      min-width: 40px;
      text-align: right;
      font-weight: 500;
      color: var(--light-theme-primary-text);
    }

    .toggles-group {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin: 12px 0;
    }

    .toggle-item {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    input[type="checkbox"] {
      width: 18px;
      height: 18px;
      cursor: pointer;
      accent-color: var(--blue);
    }

    .toggle-label {
      cursor: pointer;
      user-select: none;
      color: var(--light-theme-secondary-text);
    }

    #password-output {
      width: 100%;
      border: 1px solid #dadada;
      border-radius: 5px;
      padding: 10px 12px;
      color: var(--light-theme-primary-text);
      background: #fff;
      font-family: "Courier New", monospace;
      font-size: 0.95rem;
      margin: 12px 0;
      min-height: 60px;
      word-break: break-all;
      white-space: pre-wrap;
      overflow-y: auto;
      max-height: 300px;
      display: block;
    }

    .actions {
      display: flex;
      gap: 8px;
      margin-top: 12px;
    }

    button {
      border: 0;
      border-radius: 5px;
      font-weight: 500;
      padding: 10px 14px;
      cursor: pointer;
      transition: transform 0.1s;
      color: #fff;
      background: var(--blue);
      flex: 1;
    }

    button:hover {
      transform: scale(0.98);
    }

    button:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    .copy-feedback {
      text-align: center;
      color: var(--light-theme-secondary-text);
      font-size: 14px;
      margin-top: 12px;
      opacity: 0;
      transition: opacity 0.3s;
      pointer-events: none;
    }

    .copy-feedback.show {
      opacity: 1;
      color: var(--blue);
    }

    .section-border {
      outline: 2px dashed transparent;
      outline-offset: 5px;
      transition: 0.5s;
    }

    .section-border:hover {
      outline-color: var(--blue);
    }

    @media (width <= 640px) {
      .toggles-group {
        grid-template-columns: 1fr;
      }

      .actions {
        flex-direction: column;
      }

      button {
        width: 100%;
      }
    }
  </style>
</Layout>
