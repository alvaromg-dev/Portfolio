---
import Portfolio from "./Portfolio.astro";
import Layout from "../layouts/Layout.astro";
import Header from "@/components/Header.astro";
import "../styles/global.css";
import { getPortfolioData, getAvailableLanguages, resolveLanguageCode } from "@/lib/portfolio";
import { canAdminister, canEditPortfolio } from "@/lib/roles";
import type { HeaderNavigationState } from "@/lib/types";

const langParam = Astro.url.searchParams.get("lang");
const langCode = await resolveLanguageCode(langParam);
const data = await getPortfolioData(langCode);
const availableLanguages = await getAvailableLanguages();

const user = Astro.locals.user;
const isEditor = canEditPortfolio(user?.roles);
const isAdmin = canAdminister(user?.roles);

const navigation: HeaderNavigationState = {
  navOptions: [
    { label: "Portfolio", path: "/", active: true },
    ...(isEditor ? [{ label: "Telemetry", path: "/telemetry", active: false }] : []),
    ...(isAdmin ? [
      { label: "Users", path: "/users", active: false },
      { label: "Languages", path: "/languages", active: false },
    ] : []),
  ],
  showEditButton: isEditor,
  showLoginButton: user == null,
  showLogoutButton: user != null,
  languages: availableLanguages,
  currentLanguage: langCode,
};

---

<Layout>
  <Header navigation={navigation} currentPath="/" />
  <Portfolio data={data} canEdit={isEditor} langCode={langCode} />
</Layout>

<script>
  (async () => {
    try {
      if (navigator.webdriver === true || document.visibilityState === "prerender") return;

      const challengeResponse = await fetch("/api/telemetry/challenge", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        cache: "no-store",
      });
      if (!challengeResponse.ok) return;

      const { token } = await challengeResponse.json();
      if (!token) return;

      await new Promise((resolve) => window.setTimeout(resolve, 1200));

      await fetch("/api/telemetry/track", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        keepalive: true,
        body: JSON.stringify({
          token,
          path: window.location.pathname,
          query: window.location.search,
          source: document.referrer,
          signals: {
            language: navigator.language,
            timezone: Intl.DateTimeFormat().resolvedOptions().timeZone,
            screen: `${window.screen.width}x${window.screen.height}x${window.screen.colorDepth}`,
            visibilityState: document.visibilityState,
            webdriver: navigator.webdriver === true,
          },
        }),
      });
    } catch {
      // Telemetry should never affect the page.
    }
  })();
</script>
