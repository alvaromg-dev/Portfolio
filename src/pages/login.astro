---
import Layout from "@/layouts/Layout.astro";
import "@/styles/global.css";

const error = Astro.url.searchParams.get("error");
const locked = Astro.url.searchParams.get("locked");
const logout = Astro.url.searchParams.get("logout");

// Redirect if already authenticated
if (Astro.locals.user) {
  return Astro.redirect("/");
}
---

<Layout>
  <main>
    <section class="login-section animation-appear fadeIn">
      <h1>Secure access</h1>
      <p class="subtitle">Enter your credentials to log in.</p>

      {error && (
        <div class="alert alert-error">Incorrect username or password.</div>
      )}

      {locked && (
        <div class="alert alert-error">Too many attempts. Try again later.</div>
      )}

      {logout && (
        <div class="alert alert-success">Logged out successfully.</div>
      )}

      <form method="POST" action="/api/login" autocomplete="off">
        <label for="email">Username</label>
        <input
          type="text"
          id="email"
          name="email"
          required
          autocomplete="username"
          placeholder="usuario"
        />

        <label for="password">Password</label>
        <input
          type="password"
          id="password"
          name="password"
          required
          autocomplete="current-password"
          placeholder="••••••••"
        />

        <button type="submit">Log in</button>
      </form>

      <a class="back" href="/">← Back to portfolio</a>
    </section>
  </main>
</Layout>

<style>
  main {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 40px 0;
  }

  .login-section {
    width: min(400px, 90%);
    border-radius: 5px;
    margin: 0 auto;
  }

  h1 {
    color: var(--light-theme-primary-text);
    font-weight: 700;
    font-size: 2rem;
    margin-bottom: 8px;
  }

  .subtitle {
    margin-bottom: 24px;
    color: var(--light-theme-secondary-text);
  }

  .alert {
    padding: 10px 14px;
    border-radius: 5px;
    margin-bottom: 16px;
    font-size: 14px;
  }

  .alert-error {
    background: #fee2e2;
    color: #b91c1c;
    border: 1px solid #fecaca;
  }

  .alert-success {
    background: #d1fae5;
    color: #065f46;
    border: 1px solid #a7f3d0;
  }

  form {
    display: grid;
    gap: 12px;
  }

  label {
    color: var(--light-theme-primary-text);
    font-weight: 500;
  }

  input {
    width: 100%;
    border: 1px solid #dadada;
    border-radius: 5px;
    padding: 10px 12px;
    color: var(--light-theme-primary-text);
    background: #fff;
    outline: none;
  }

  input:focus {
    border-color: var(--blue);
  }

  button {
    border: 0;
    border-radius: 5px;
    font-weight: 500;
    padding: 12px;
    cursor: pointer;
    transition: transform 0.1s;
    color: var(--light-theme-primary-text);
    background: var(--blue);
    margin-top: 8px;
  }

  button:hover {
    transform: scale(0.98);
  }

  .back {
    display: inline-block;
    margin-top: 20px;
    color: var(--light-theme-secondary-text);
    text-decoration: none;
    font-weight: 500;
  }

  .back:hover {
    color: var(--light-theme-primary-text);
  }
</style>
